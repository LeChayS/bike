@model IEnumerable<bike.Models.ThietHai>

@{
    ViewData["Title"] = "Quản lý thiệt hại";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/quanlythiethai/qlthiethai-index.css">
}

@section Scripts {
    <script src="/js/quanlythiethai/index.js"></script>
}

@Html.AntiForgeryToken()
<div class="container-fluid">
    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle me-3" style="font-size: 2.5rem;"></i>
            <div>
                <h2>Quản lý thiệt hại</h2>
                <p>Quản lý và theo dõi các báo cáo thiệt hại xe</p>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-container">
        <div class="row mb-4">
            <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                <div class="stat-card">
                    <div class="stat-icon blue text-white">
                        <i class="bi bi-list-ul"></i>
                    </div>
                    <div class="stat-number">@ViewData["TongThietHai"]</div>
                    <div class="stat-label">Tổng thiệt hại</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                <div class="stat-card">
                    <div class="stat-icon red text-white">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div class="stat-number">@ViewData["ThietHaiChuaXuLy"]</div>
                    <div class="stat-label">Chưa xử lý</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                <div class="stat-card">
                    <div class="stat-icon orange text-white">
                        <i class="bi bi-gear"></i>
                    </div>
                    <div class="stat-number">@ViewData["ThietHaiDangXuLy"]</div>
                    <div class="stat-label">Đang xử lý</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                <div class="stat-card">
                    <div class="stat-icon green text-white">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div class="stat-number">@ViewData["ThietHaiDaXuLy"]</div>
                    <div class="stat-label">Đã xử lý</div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                <div class="stat-card">
                    <div class="stat-icon cyan text-white">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <div class="stat-number">@(((decimal)ViewData["TongDenBu"]).ToString("N0"))đ</div>
                    <div class="stat-label">Tổng đền bù</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="search-filter-section">
        <div class="row">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo xe, khách hàng...">
                    <button class="btn btn-outline-secondary" type="button" onclick="searchThietHai()">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-3">
                <select id="statusFilter" class="form-control" onchange="filterByStatus()">
                    <option value="Tất cả">Tất cả trạng thái</option>
                    <option value="Chưa xử lý">Chưa xử lý</option>
                    <option value="Đang xử lý">Đang xử lý</option>
                    <option value="Đã xử lý">Đã xử lý</option>
                    <option value="Đã đền bù">Đã đền bù</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-primary" onclick="resetFilter()">
                    <i class="bi bi-arrow-clockwise"></i> Làm mới
                </button>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Thiệt hại & Xe</th>
                        <th>Mô tả</th>
                        <th>Ngày xảy ra</th>
                        <th>Trạng thái</th>
                        <th>Số tiền đền bù</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="thietHaiTableBody">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge badge-@item.LoaiThietHaiClass">@item.LoaiThietHai</span>
                                <br><small class="text-muted">@item.Xe?.TenXe (@item.Xe?.BienSoXe)</small>
                            </td>
                            <td>@item.MoTaThietHai</td>
                            <td>@item.NgayXayRa.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge badge-@item.TrangThaiClass">@item.TrangThaiXuLy</span>
                            </td>
                            <td class="text-success font-weight-bold">@item.SoTienDenBu.ToString("N0")đ</td>
                            <td class="text-center">
                                <button onclick="showEditModal(@item.MaThietHai)" class="btn btn-warning btn-sm" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button onclick="showChiTietModal(@item.MaThietHai)" class="btn btn-info btn-sm" title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button onclick="showDeleteModal(@item.MaThietHai)" class="btn btn-danger btn-sm" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Chi tiết thiệt hại -->
<div id="chiTietModal" class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header">
            <h3 class="modal-title">
                <i class="bi bi-info-circle me-2"></i>
                Chi tiết thiệt hại
            </h3>
            <button class="modal-close" onclick="closeChiTietModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="modal-body" id="chiTietModalBody">
            <div class="text-center">
                <div class="loading-spinner"></div>
                <p class="mt-2">Đang tải thông tin...</p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="modal-btn modal-btn-secondary" onclick="closeChiTietModal()">
                <i class="bi bi-x-circle me-1"></i>
                Đóng
            </button>
        </div>
    </div>
</div>

<!-- Modal Edit thiệt hại (Custom CSS) -->
<div id="editModal" class="custom-modal-overlay">
    <div class="custom-modal-container">
        <div class="custom-modal-header">
            <h3 class="custom-modal-title">
                <i class="bi bi-pencil-square"></i>
                Chỉnh sửa thiệt hại
            </h3>
            <button class="custom-modal-close" onclick="closeEditModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="custom-modal-body" id="editModalBody">
            <div class="text-center">
                <div class="loading-spinner"></div>
                <p>Đang tải thông tin...</p>
            </div>
        </div>
        <div class="custom-modal-footer">
            <button class="custom-modal-btn custom-modal-btn-secondary" onclick="closeEditModal()">
                <i class="bi bi-x-circle"></i>
                Hủy
            </button>
            <button class="custom-modal-btn custom-modal-btn-primary" onclick="saveThietHai()">
                <i class="bi bi-check-circle"></i>
                Lưu thay đổi
            </button>
        </div>
    </div>
</div>

<!-- Modal Xác nhận xóa thiệt hại -->
<div id="deleteModal" class="modal-overlay">
    <div class="modal-container" style="max-width: 500px;">
        <div class="modal-header">
            <h3 class="modal-title">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Xác nhận xóa thiệt hại
            </h3>
            <button class="modal-close" onclick="closeDeleteModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="modal-body" id="deleteModalBody">
            <div class="text-center">
                <div class="loading-spinner"></div>
                <p class="mt-2">Đang tải thông tin...</p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="modal-btn modal-btn-secondary" onclick="closeDeleteModal()">
                <i class="bi bi-x-circle me-1"></i>
                Hủy
            </button>
            <button class="modal-btn modal-btn-danger" onclick="confirmDelete()">
                <i class="bi bi-trash me-1"></i>
                Xóa thiệt hại
            </button>
        </div>
    </div>
</div>