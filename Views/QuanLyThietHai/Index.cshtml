        }).fail(function() {
            modalBody.innerHTML = `
                <div class="text-center text-danger">
                    <i class="bi bi-exclamation-triangle" style="font-size: 3rem;"></i>
                    <p class="mt-2">Không thể kết nối đến máy chủ</p>
                    <p class="text-muted">Vui lòng thử lại sau</p>
                </div>
            `;
