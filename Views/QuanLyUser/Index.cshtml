@model IEnumerable<bike.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
<style>
    .user-table-card { box-shadow: 0 2px 16px rgba(0,0,0,0.08); border-radius: 16px; overflow: hidden; }
    .role-badge { border-radius: 12px; font-size: 0.9em; padding: 0.2em 0.8em; }
    .role-admin { background: #e74c3c; color: #fff; }
    .role-staff { background: #2980b9; color: #fff; }
    .role-user { background: #27ae60; color: #fff; }
    .status-badge { border-radius: 12px; font-size: 0.9em; padding: 0.2em 0.8em; }
    .status-active { background: #2ecc71; color: #fff; }
    .status-inactive { background: #b2bec3; color: #636e72; }
    .modal-header { border-bottom: 1px solid #eee; }
    .modal-footer { border-top: 1px solid #eee; }
    .table thead { background: #f8f9fa; }
    .btn-action { margin-right: 4px; }
</style>
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-people"></i> Quản lý người dùng</h2>
        <a href="/QuanLyUser/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm người dùng</a>
    </div>
    <div class="user-table-card p-3">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>#@user.Id</td>
                        <td>@user.Ten</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="role-badge @(user.VaiTro == "Admin" ? "role-admin" : user.VaiTro == "Staff" ? "role-staff" : "role-user")">
                                @(user.VaiTro == "Admin" ? "Quản trị" : user.VaiTro == "Staff" ? "Nhân viên" : "Khách hàng")
                            </span>
                        </td>
                        <td>
                            <span class="status-badge @(user.IsActive ? "status-active" : "status-inactive")">
                                @(user.IsActive ? "Hoạt động" : "Khóa")
                            </span>
                        </td>
                        <td>@user.NgayTao.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a href="/QuanLyUser/Edit/@user.Id" class="btn btn-warning btn-sm btn-action" title="Sửa"><i class="bi bi-pencil"></i></a>
                            <a href="/QuanLyUser/Permissions/@user.Id" class="btn btn-info btn-sm btn-action" title="Quản lý quyền"><i class="bi bi-shield-check"></i></a>
                            @if (user.Id != int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier).Value))
                            {
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display:inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm btn-action" title="Xóa"><i class="bi bi-trash"></i></button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <!-- Thông báo -->
    <div id="userAlert" style="position:fixed;top:20px;right:20px;z-index:9999;min-width:300px;"></div>
</div> 