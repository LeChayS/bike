@model bike.ViewModel.UserPermissionViewModel
@{
    ViewData["Title"] = "Quản lý quyền người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    // Helper function để lấy permission options
    var permissionOptions = bike.ViewModel.UserPermissionViewModel.PermissionOptions;
}
@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/quanlyuser/permissions.css" />
}

@section Scripts {
    <script>
        // Thêm hiệu ứng cho radio buttons
        document.querySelectorAll('.radio-item').forEach(item => {
            item.addEventListener('click', function() {
                const radio = this.querySelector('input[type="radio"]');
                radio.checked = true;

                // Reset style cho tất cả items trong cùng group
                const name = radio.name;
                document.querySelectorAll(`input[name="${name}"]`).forEach(r => {
                    r.closest('.radio-item').style.borderColor = '#e9ecef';
                    r.closest('.radio-item').style.background = 'white';
                });

                // Highlight item được chọn
                this.style.borderColor = '#007bff';
                this.style.background = '#f8f9ff';
            });
        });
    </script>
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-shield-check"></i> Quản lý quyền người dùng</h2>
        <a href="/QuanLyUser/Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="user-info">
        <h4><i class="bi bi-person-circle"></i> @Model.UserName</h4>
        <p><i class="bi bi-envelope"></i> @Model.UserEmail</p>
    </div>

    <form asp-action="Permissions" method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="UserName" />
        <input type="hidden" asp-for="UserEmail" />

        <div class="permission-card p-4">
            <!-- Quản lý xe -->
            <div class="permission-section">
                <h5><i class="bi bi-bicycle"></i> Quản lý xe</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="XePermission" value="@option.Value" id="xe_@option.Value" />
                            <label for="xe_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý loại xe -->
            <div class="permission-section">
                <h5><i class="bi bi-tags"></i> Quản lý loại xe</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="LoaiXePermission" value="@option.Value" id="loaixe_@option.Value" />
                            <label for="loaixe_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý hợp đồng -->
            <div class="permission-section">
                <h5><i class="bi bi-file-earmark-text"></i> Quản lý hợp đồng</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="HopDongPermission" value="@option.Value" id="hopdong_@option.Value" />
                            <label for="hopdong_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý hóa đơn -->
            <div class="permission-section">
                <h5><i class="bi bi-receipt"></i> Quản lý hóa đơn</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="HoaDonPermission" value="@option.Value" id="hoadon_@option.Value" />
                            <label for="hoadon_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý nhân viên -->
            <div class="permission-section">
                <h5><i class="bi bi-people"></i> Quản lý nhân viên</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="NhanVienPermission" value="@option.Value" id="nhanvien_@option.Value" />
                            <label for="nhanvien_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý người dùng -->
            <div class="permission-section">
                <h5><i class="bi bi-person-gear"></i> Quản lý người dùng</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="UserPermission" value="@option.Value" id="user_@option.Value" />
                            <label for="user_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý banner -->
            <div class="permission-section">
                <h5><i class="bi bi-image"></i> Quản lý banner</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="BannerPermission" value="@option.Value" id="banner_@option.Value" />
                            <label for="banner_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý thiệt hại -->
            <div class="permission-section">
                <h5><i class="bi bi-exclamation-triangle"></i> Quản lý thiệt hại</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="ThietHaiPermission" value="@option.Value" id="thiet hai_@option.Value" />
                            <label for="thiet hai_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Báo cáo thống kê -->
            <div class="permission-section">
                <h5><i class="bi bi-graph-up"></i> Báo cáo thống kê</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="BaoCaoPermission" value="@option.Value" id="baocao_@option.Value" />
                            <label for="baocao_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>

            <!-- Quản lý hình ảnh xe -->
            <div class="permission-section">
                <h5><i class="bi bi-images"></i> Quản lý hình ảnh xe</h5>
                <div class="radio-group">
                    @foreach (var option in permissionOptions)
                    {
                        <div class="radio-item">
                            <input type="radio" asp-for="HinhAnhXePermission" value="@option.Value" id="hinhanhxe_@option.Value" />
                            <label for="hinhanhxe_@option.Value">@option.Text</label>
                        </div>
                    }
                </div>
            </div>



            <div class="d-flex justify-content-between mt-4">
                <a href="/QuanLyUser/Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Lưu quyền</button>
            </div>
        </div>
    </form>
</div>