@model bike.Models.HopDong
@{
    ViewData["Title"] = "Xác Nhận Đặt Xe Thành Công";
    Layout = "~/Views/Shared/_HomePage.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart/cart-confirm-contract.css" />
}

<div class="confirmation-container">
    <!-- Header -->
    <div class="confirmation-header">
        <div class="confirmation-icon">
            <i class="bi bi-check-circle"></i>
        </div>
        <h1>Đặt Xe Thành Công!</h1>
        <p class="mb-0 fs-5">Hợp đồng HD@(Model.MaHopDong.ToString("D6")) đã được tạo</p>
    </div>

    <!-- Body -->
    <div class="confirmation-body">
        <!-- Thông báo quan trọng -->
        <div class="important-notice">
            <div class="notice-title">
                <i class="bi bi-info-circle"></i> Thông tin quan trọng
            </div>
            <ul class="mb-0">
                <li>Hợp đồng của bạn đang ở trạng thái <strong>"Chờ xác nhận"</strong></li>
                <li>Chúng tôi sẽ liên hệ với bạn trong vòng <strong>24 giờ</strong> để xác nhận và sắp xếp giao xe</li>
                <li>Vui lòng chuẩn bị đầy đủ giấy tô CCCD/CMND để làm thủ tục thuê xe</li>
                <li>Nếu có thay đổi, vui lòng liên hệ <strong>0908.630.065</strong></li>
            </ul>
        </div>

        <!-- Thông tin hợp đồng -->
        <h4 class="mb-3"><i class="bi bi-file-earmark-text"></i> Thông tin hợp đồng</h4>
        <div class="contract-info">
            <div class="row">
                <div class="col-md-6">
                    <div class="info-row">
                        <span class="info-label">Mã hợp đồng:</span>
                        <span class="info-value">HD@(Model.MaHopDong.ToString("D6"))</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Khách hàng:</span>
                        <span class="info-value">@Model.HoTenKhach</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số điện thoại:</span>
                        <span class="info-value">@Model.SoDienThoai</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-row">
                        <span class="info-label">Ngày tạo:</span>
                        <span class="info-value">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Trạng thái:</span>
                        <span class="status-badge">@Model.TrangThai</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số xe thuê:</span>
                        <span class="info-value">@Model.ChiTietHopDong.Count xe</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách xe -->
        <h4 class="mb-3"><i class="bi bi-bicycle"></i> Danh sách xe đã đặt</h4>
        @foreach (var chiTiet in Model.ChiTietHopDong)
        {
            <div class="vehicle-card">
                <div class="vehicle-header">
                    <div class="vehicle-name">@chiTiet.Xe?.TenXe</div>
                    <div class="vehicle-price">@chiTiet.ThanhTien.ToString("N0")đ</div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-2">
                        @if (!string.IsNullOrEmpty(chiTiet.Xe?.HinhAnhHienThi))
                        {
                            <img src="/images/xe/@chiTiet.Xe.HinhAnhHienThi" alt="@chiTiet.Xe.TenXe" class="vehicle-image" onerror="this.onerror=null;this.src='/images/default.jpg';" />
                        }
                        else
                        {
                            <img src="/images/default.jpg" alt="@chiTiet.Xe?.TenXe" class="vehicle-image" />
                        }
                    </div>
                    <div class="col-md-10">
                        <div class="row">
                            <div class="col-md-6">
                                <small class="text-muted">
                                    <strong>Biển số:</strong> @chiTiet.Xe?.BienSoXe<br>
                                    <strong>Hãng xe:</strong> @chiTiet.Xe?.HangXe @chiTiet.Xe?.DongXe<br>
                                    <strong>Loại xe:</strong> @chiTiet.Xe?.LoaiXe?.TenLoaiXe
                                </small>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted">
                                    <strong>Từ:</strong> @chiTiet.NgayNhanXe.ToString("dd/MM/yyyy")<br>
                                    <strong>Đến:</strong> @chiTiet.NgayTraXeDuKien.ToString("dd/MM/yyyy")<br>
                                    <strong>Số ngày:</strong> @chiTiet.SoNgayThue ngày
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="vehicle-details">
                    <div class="detail-item">
                        <div class="detail-label">Giá/ngày</div>
                        <div class="detail-value">@chiTiet.GiaThueNgay.ToString("N0")đ</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Số ngày</div>
                        <div class="detail-value">@chiTiet.SoNgayThue ngày</div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-label">Thành tiền</div>
                        <div class="detail-value text-success">@chiTiet.ThanhTien.ToString("N0")đ</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(chiTiet.GhiChu))
                {
                    <div class="mt-2">
                        <small class="text-muted"><strong>Ghi chú:</strong> @chiTiet.GhiChu</small>
                    </div>
                }
            </div>
        }

        <!-- Tổng tiền -->
        <div class="total-section">
            <h4>Tổng Tiền Hợp Đồng</h4>
            <div class="total-amount">@Model.TongTien.ToString("N0")đ</div>
            <p class="mb-0">Tiền cọc và các khoản phí sẽ được thỏa thuận khi giao xe</p>
        </div>

        <!-- Ghi chú chung -->
        @if (!string.IsNullOrEmpty(Model.GhiChu))
        {
            <div class="alert alert-info">
                <strong><i class="bi bi-chat-text"></i> Ghi chú:</strong> @Model.GhiChu
            </div>
        }

        <!-- Action buttons -->
        <div class="action-buttons">
            <a href="@Url.Action("Index", "Home")" class="btn-success-custom">
                <i class="bi bi-house"></i> Về trang chủ
            </a>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="QuanLyHopDong" asp-action="ChiTiet" asp-route-id="@Model.MaHopDong" 
                   class="btn-primary-custom">
                    <i class="bi bi-eye"></i> Xem chi tiết hợp đồng
                </a>
            }
        </div>

        <!-- Liên hệ -->
        <div class="text-center mt-4">
            <p class="text-muted">
                <i class="bi bi-telephone"></i> Hotline hỗ trợ: <strong>0908.630.065</strong><br>
                <i class="bi bi-clock"></i> Thời gian làm việc: 8:00 - 20:00 hàng ngày
            </p>
        </div>
    </div>
</div> 