@using bike.Repository
@using Microsoft.EntityFrameworkCore
@using bike.Services
@inject BikeDbContext _context
@inject IPermissionService _permissionService
@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var userId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
    
    // Lấy số đơn chờ xử lý mới trong ngày
    int donChoXuLyMoi = 0;
    if (userRole == "Admin" || userRole == "Staff")
    {
        var homNay = DateTime.Today;
        donChoXuLyMoi = await _context.DatCho
            .CountAsync(d => (d.TrangThai == "Chờ xác nhận" || d.TrangThai == "Đang giữ chỗ") 
                           && d.NgayDat.Date == homNay);
    }
    
    // Lấy số thiệt hại chưa xử lý
    int thietHaiChuaXuLy = 0;
    if (userRole == "Admin" || userRole == "Staff")
    {
        thietHaiChuaXuLy = await _context.ThietHai
            .CountAsync(t => t.TrangThaiXuLy == "Chưa xử lý" || t.TrangThaiXuLy == "Đang xử lý");
    }
    

}
<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <h3>ADMIN PANEL</h3>
    </div>
    <ul class="sidebar-menu">
        @* Dashboard - Chỉ Admin *@
        @if (userRole == "Admin")
        {
            <li>
                <a asp-controller="BaoCao" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span class="menu-text">Dashboard</span>
                </a>
            </li>
            <li>
                <a asp-controller="ThongKeBaoCao" asp-action="Index">
                    <i class="bi bi-bar-chart-line"></i>
                    <span class="menu-text">Thống kê & Báo cáo</span>
                </a>
            </li>
        }

        @* Menu cho Admin và Staff *@
        @if (userRole == "Admin" || userRole == "Staff")
        {
            <li>
                <a asp-controller="QuanLyHopDong" asp-action="Index" style="position: relative;">
                    <i class="bi bi-receipt"></i>
                    <span class="menu-text">Quản lý hợp đồng</span>
                    @if (donChoXuLyMoi > 0)
                    {
                        <span class="sidebar-notification-badge">@donChoXuLyMoi</span>
                    }
                </a>
            </li>

            <li>
                <a asp-controller="QuanLyHoaDon" asp-action="Index">
                    <i class="bi bi-receipt-cutoff"></i>
                    <span class="menu-text">Quản lý hóa đơn</span>
                </a>
            </li>
            <li>
                <a asp-controller="Xe" asp-action="Index">
                    <i class="bi bi-scooter"></i>
                    <span class="menu-text">Quản lý xe</span>
                </a>
            </li>
            <li>
                <a asp-controller="LoaiXe" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span class="menu-text">Quản lý loại xe</span>
                </a>
            </li>
            <li>
                <a asp-controller="QuanLyThietHai" asp-action="Index" style="position: relative;">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span class="menu-text">Quản lý thiệt hại</span>
                    @if (thietHaiChuaXuLy > 0)
                    {
                        <span class="sidebar-notification-badge sidebar-notification-badge-warning">@thietHaiChuaXuLy</span>
                    }
                </a>
            </li>

            <li>
                <a asp-controller="QuanLyBanner" asp-action="Index">
                    <i class="bi bi-image"></i> <span class="menu-text">Quản lý banner</span>
                </a>
            </li>
        }

        @* Quản lý người dùng - Chỉ Admin *@
        @if (userRole == "Admin")
        {
            <li>
                <a asp-controller="QuanLyUser" asp-action="Index">
                    <i class="bi bi-people-fill"></i>
                    <span class="menu-text">Quản lý người dùng</span>
                </a>
            </li>
        }
    </ul>
</div>

<style>
    /* Badge thông báo cho sidebar menu */
    .sidebar-notification-badge {
        position: absolute;
        top: 8px;
        right: 12px;
        background: linear-gradient(135deg, #ff4757 0%, #ff3838 100%);
        color: white;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: bold;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        box-shadow: 0 2px 6px rgba(255, 71, 87, 0.4);
        border: 2px solid white;
        animation: pulse-sidebar 2s infinite;
        z-index: 10;
    }

    /* Badge thông báo cho thiệt hại (màu cam) */
    .sidebar-notification-badge-warning {
        background: linear-gradient(135deg, #ffa726 0%, #ff9800 100%);
        box-shadow: 0 2px 6px rgba(255, 167, 38, 0.4);
        animation: pulse-sidebar-warning 2s infinite;
    }

    /* Thêm thuộc tính để sidebar có thể cuộn dọc */
    .sidebar {
        height: 100vh;
        overflow-y: auto;
    }
    /* Scrollbar cho Chrome, Edge, Safari */
    .sidebar::-webkit-scrollbar {
        width: 8px;
        background: #f1f1f1;
        border-radius: 8px;
    }
    .sidebar::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 8px;
    }
    .sidebar::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }
    /* Scrollbar cho Firefox */
    .sidebar {
        scrollbar-width: thin;
        scrollbar-color: #764ba2 #f1f1f1;
    }

    @@keyframes pulse-sidebar {
        0%, 100% { 
            transform: scale(1); 
            box-shadow: 0 2px 6px rgba(255, 71, 87, 0.4);
        }
        50% { 
            transform: scale(1.1); 
            box-shadow: 0 4px 12px rgba(255, 71, 87, 0.6);
        }
    }

    @@keyframes pulse-sidebar-warning {
        0%, 100% { 
            transform: scale(1); 
            box-shadow: 0 2px 6px rgba(255, 167, 38, 0.4);
        }
        50% { 
            transform: scale(1.1); 
            box-shadow: 0 4px 12px rgba(255, 167, 38, 0.6);
        }
    }

    /* Đảm bảo sidebar menu item có đủ không gian cho badge */
    .sidebar-menu li a {
        position: relative;
        padding-right: 45px !important; /* Tăng padding bên phải để có chỗ cho badge */
    }

    /* Responsive cho badge trên màn hình nhỏ */
    @@media (max-width: 768px) {
        .sidebar-notification-badge {
            width: 18px;
            height: 18px;
            font-size: 9px;
            right: 8px;
            top: 6px;
        }
    }
</style>