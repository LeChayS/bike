@model bike.Models.Xe
@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .delete-container {
        max-width: 600px;
        margin: 50px auto;
    }

    .delete-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .delete-header {
        background: linear-gradient(135deg, #ee0979 0%, #ff6a00 100%);
        color: white;
        padding: 30px;
        text-align: center;
    }

    .delete-body {
        padding: 30px;
    }

    .warning-icon {
        font-size: 80px;
        margin-bottom: 20px;
    }

    .vehicle-info {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
        margin: 20px 0;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #e9ecef;
    }

        .info-item:last-child {
            border-bottom: none;
        }

    .info-label {
        font-weight: 600;
        color: #6c757d;
    }

    .info-value {
        color: #212529;
    }

    .vehicle-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .btn-delete-confirm {
        background: linear-gradient(135deg, #ee0979 0%, #ff6a00 100%);
        border: none;
        padding: 12px 30px;
        font-weight: 500;
        transition: all 0.3s;
    }

        .btn-delete-confirm:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(238, 9, 121, 0.4);
        }

    .alert-custom {
        background: #fff3cd;
        border: 2px solid #ffeaa7;
        color: #856404;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 20px;
    }

    .alert-history {
        background: #d1ecf1;
        border: 2px solid #bee5eb;
        color: #0c5460;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 20px;
    }

    .status-badge {
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
    }

    .status-available {
        background: #d4edda;
        color: #155724;
    }

    .status-rented {
        background: #fff3cd;
        color: #856404;
    }

    .status-maintenance {
        background: #f8d7da;
        color: #721c24;
    }

    .history-indicator {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        background: #17a2b8;
        color: white;
        border-radius: 15px;
        font-size: 12px;
    }

    /* Custom Modal Styles */
    .custom-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1050;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .custom-modal-overlay.show {
        opacity: 1;
        visibility: visible;
    }

    .custom-modal {
        background: white;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        max-width: 500px;
        width: 90%;
        transform: scale(0.7);
        transition: transform 0.3s ease;
    }

    .custom-modal-overlay.show .custom-modal {
        transform: scale(1);
    }

    .custom-modal-header {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 20px;
        border-radius: 10px 10px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .custom-modal-title {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }

    .custom-modal-close {
        background: none;
        border: none;
        color: white;
        font-size: 20px;
        cursor: pointer;
        padding: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: background-color 0.3s;
    }

    .custom-modal-close:hover {
        background-color: rgba(255, 255, 255, 0.2);
    }

    .custom-modal-body {
        padding: 20px;
    }

    .custom-modal-footer {
        padding: 15px 20px;
        border-top: 1px solid #dee2e6;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }
</style>

<div class="container">
    <div class="delete-container">
        <div class="delete-card">
            <!-- Header -->
            <div class="delete-header">
                <i class="bi bi-exclamation-triangle warning-icon"></i>
                <h2>Xác Nhận Xóa Xe</h2>
                <p class="mb-0">Hành động này không thể hoàn tác</p>
            </div>

            <!-- Body -->
            <div class="delete-body">
                <!-- Cảnh báo xe đang thuê (không cho xóa) -->
                @if (Model.TrangThai == "Đang thuê")
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                        <strong>Không thể xóa!</strong> Xe này đang trong hợp đồng cho thuê.
                        Vui lòng chờ hợp đồng kết thúc để thực hiện xóa.
                    </div>
                }



                <!-- Hình ảnh xe -->
                                        @if (!string.IsNullOrEmpty(Model.HinhAnhHienThi))
                        {
                            <img src="~/images/xe/@Model.HinhAnhHienThi" alt="@Model.TenXe" class="vehicle-image" />
                }

                <!-- Thông tin xe -->
                <div class="vehicle-info">
                    <h5 class="mb-3">
                        <i class="bi bi-bicycle"></i> Thông Tin Xe
                        @if (ViewBag.HasContracts == true)
                        {
                            <span class="history-indicator float-end">
                                <i class="bi bi-clock-history"></i> Có lịch sử thuê
                            </span>
                        }
                    </h5>

                    <div class="info-item">
                        <span class="info-label">Mã xe:</span>
                        <span class="info-value">#XE@(Model.MaXe.ToString("D3"))</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Tên xe:</span>
                        <span class="info-value"><strong>@Model.TenXe</strong></span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Biển số:</span>
                        <span class="info-value">@Model.BienSoXe</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Hãng xe:</span>
                        <span class="info-value">@Model.HangXe</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Dòng xe:</span>
                        <span class="info-value">@Model.DongXe</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Loại xe:</span>
                        <span class="info-value">@Model.LoaiXe?.TenLoaiXe</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Giá thuê:</span>
                        <span class="info-value text-danger"><strong>@Model.GiaThue.ToString("N0")đ/ngày</strong></span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Trạng thái:</span>
                        <span class="info-value">
                            @{
                                string statusClass = Model.TrangThai switch
                                {
                                    "Sẵn sàng" => "status-available",
                                    "Đang thuê" => "status-rented",
                                    "Bảo trì" => "status-maintenance",
                                    _ => ""
                                };
                            }
                            <span class="status-badge @statusClass">@Model.TrangThai</span>
                        </span>
                    </div>
                </div>

                <!-- Form xác nhận -->
                @if (Model.TrangThai != "Đang thuê")
                {
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Hủy bỏ
                        </a>
                        <button type="button" class="btn btn-danger btn-lg btn-delete-confirm" onclick="showDeleteModal()">
                            <i class="bi bi-trash"></i> Xác nhận xóa
                        </button>
                    </div>
                }
                else
                {
                    <div class="text-center mt-4">
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="custom-modal-overlay" id="deleteModal">
    <div class="custom-modal">
        <div class="custom-modal-header">
            <h5 class="custom-modal-title">
                <i class="bi bi-exclamation-triangle"></i> Xác nhận xóa xe
            </h5>
            <button type="button" class="custom-modal-close" onclick="closeDeleteModal()">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="custom-modal-body">
            <p>Bạn có chắc chắn muốn xóa xe <strong>@Model.TenXe</strong> (Biển số: @Model.BienSoXe)?</p>
            <p class="text-muted mb-0">Hành động này sẽ đánh dấu xe là "Đã xóa" và ẩn khỏi danh sách chính.</p>
        </div>
        <div class="custom-modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">
                <i class="bi bi-x-circle"></i> Hủy bỏ
            </button>
            <form asp-action="Delete" method="post" style="display: inline;">
                <input type="hidden" asp-for="MaXe" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Xác nhận xóa
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiển thị thông báo TempData nếu có
        @if (TempData["Error"] != null)
        {
            <text>
                    toastr.error('@TempData["Error"]');
            </text>
        }

        // Function to show delete confirmation modal
        function showDeleteModal() {
            document.getElementById('deleteModal').classList.add('show');
        }

        // Function to close delete confirmation modal
        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('show');
        }

        // Close modal when clicking outside
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('deleteModal').addEventListener('click', function(e) {
                if (e.target === this) {
                    closeDeleteModal();
                }
            });

            // Close modal with Escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    closeDeleteModal();
                }
            });
        });
    </script>
}