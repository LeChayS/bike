@model IEnumerable<bike.Models.ChiTietHopDong>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Lịch sử hợp đồng";
    var xe = ViewBag.Xe as bike.Models.Xe;
}

@section Styles {
    <link rel="stylesheet" href="~/css/xe/xe-index.css" />
    <link rel="stylesheet" href="~/css/shared/responsive.css" />
    <link rel="stylesheet" href="/css/xe/lichsuhopdong.css">
}

@section Scripts {
    <script src="/js/xe/lichsuhopdong.js"></script>
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Lịch sử hợp đồng</h1>
            <p class="text-muted mb-0">
                <strong>Xe:</strong> @xe.TenXe - @xe.BienSoXe 
                <span class="badge bg-secondary ms-2">@xe.LoaiXe?.TenLoaiXe</span>
            </p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

        <!-- Bộ lọc -->
    <div class="filter-section">
        <form method="get" class="row g-3">
            <input type="hidden" name="id" value="@xe.MaXe" />
            <input type="hidden" name="timeFilter" id="timeFilterInput" value="@ViewBag.TimeFilter" />
            
            <!-- Tìm kiếm -->
            <div class="col-md-4">
                <label class="form-label">Tìm kiếm</label>
                <input type="text" name="searchString" class="form-control" 
                       placeholder="Tên hoặc số điện thoại khách hàng..." 
                       value="@ViewBag.SearchString" />
            </div>

            <!-- Bộ lọc thời gian nhanh -->
            <div class="col-md-8">
                <label class="form-label">Bộ lọc thời gian</label>
                <div>
                    <button type="button" data-timefilter="" 
                            class="btn btn-outline-secondary time-filter-btn @(string.IsNullOrEmpty(ViewBag.TimeFilter) ? "active" : "")">
                        Tất cả
                    </button>
                    <button type="button" data-timefilter="week" 
                            class="btn btn-outline-secondary time-filter-btn @(ViewBag.TimeFilter == "week" ? "active" : "")">
                        Tuần này
                    </button>
                    <button type="button" data-timefilter="month" 
                            class="btn btn-outline-secondary time-filter-btn @(ViewBag.TimeFilter == "month" ? "active" : "")">
                        Tháng này
                    </button>
                    <button type="button" data-timefilter="year" 
                            class="btn btn-outline-secondary time-filter-btn @(ViewBag.TimeFilter == "year" ? "active" : "")">
                        Năm nay
                    </button>
                </div>
            </div>

            <!-- Khoảng thời gian tùy chỉnh -->
            <div class="col-md-6">
                <label class="form-label">Từ ngày</label>
                <input type="date" name="startDate" class="form-control" 
                       value="@(ViewBag.StartDate?.ToString("yyyy-MM-dd"))" />
                <small class="text-muted">Chọn ngày bắt đầu</small>
            </div>
            <div class="col-md-6">
                <label class="form-label">Đến ngày</label>
                <input type="date" name="endDate" class="form-control" 
                       value="@(ViewBag.EndDate?.ToString("yyyy-MM-dd"))" />
            </div>

            <!-- Nút lọc -->
            <div class="col-12">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
                <a asp-action="LichSuHopDong" asp-route-id="@xe.MaXe" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Làm mới
                </a>
            </div>
        </form>
    </div>

    <!-- Container cho nội dung động -->
    <div id="contentContainer">
        @Html.Partial("_LichSuHopDongPartial", Model)
    </div>
</div>