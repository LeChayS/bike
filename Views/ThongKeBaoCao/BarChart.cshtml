@model dynamic
@{
    ViewData["Title"] = "Biểu Đồ Cột - Thống Kê Tài Chính Chi Tiết";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles{
    <link rel="stylesheet" href="/css/thongkebaocao/thongkebaocao-barchart.css">
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/thongkebaocao/barchart.js"></script>
}

<div class="chart-container">
    <div class="chart-header">
        <h1 class="chart-title">
            <i class="bi bi-bar-chart-fill"></i> Biểu Đồ Cột - Thống Kê Tài Chính Chi Tiết
        </h1>
        <p class="chart-subtitle">
            Phân tích doanh thu gốc, doanh thu sau chi tiêu, chi tiêu, thiệt hại và lợi nhuận thực tế theo thời gian
        </p>
    </div>

    <div class="filter-section">
        <h5 class="mb-3 text-center">
            <i class="bi bi-calendar-range"></i> Chọn khoảng thời gian
        </h5>
        <div class="filter-buttons">
            <button class="filter-btn" data-filter="today">Hôm nay</button>
            <button class="filter-btn" data-filter="7days">7 ngày qua</button>
            <button class="filter-btn" data-filter="week">Tuần này</button>
            <button class="filter-btn" data-filter="month">30 ngày qua</button>
            <button class="filter-btn" data-filter="year">12 tháng qua</button>
        </div>
        
        <div class="custom-date-section">
            <div class="date-input-group">
                <label for="startDate">Từ ngày:</label>
                <input type="date" id="startDate" name="startDate" />
            </div>
            <div class="date-input-group">
                <label for="endDate">Đến ngày:</label>
                <input type="date" id="endDate" name="endDate" />
            </div>
            <button type="button" class="apply-date-btn" id="applyCustomDate">
                <i class="bi bi-check-circle"></i> Áp dụng
            </button>
        </div>
    </div>

    <div id="currentPeriodInfo" class="current-period-info" style="display: none;">
        <i class="bi bi-calendar-check"></i> <span id="periodInfoText"></span>
    </div>

    <div class="chart-wrapper">
        <canvas id="barChart"></canvas>
        <div id="loading" class="loading">
            <i class="bi bi-hourglass-split"></i> Đang tải dữ liệu...
        </div>
        <div id="error" class="error-message" style="display: none;">
            <i class="bi bi-exclamation-triangle"></i> Có lỗi xảy ra khi tải dữ liệu
        </div>
    </div>

    <div class="legend">
        <div class="legend-item" data-dataset="0">
            <div class="legend-color" style="background-color: rgba(54, 162, 235, 0.8);"></div>
            <span>Doanh thu gốc</span>
        </div>
        <div class="legend-item" data-dataset="1">
            <div class="legend-color" style="background-color: rgba(100, 149, 237, 0.8);"></div>
            <span>Doanh thu sau chi tiêu</span>
        </div>
        <div class="legend-item" data-dataset="2">
            <div class="legend-color" style="background-color: rgba(255, 99, 132, 0.8);"></div>
            <span>Chi tiêu</span>
        </div>
        <div class="legend-item" data-dataset="3">
            <div class="legend-color" style="background-color: rgba(255, 159, 64, 0.8);"></div>
            <span>Thiệt hại</span>
        </div>
        <div class="legend-item" data-dataset="4">
            <div class="legend-color" style="background-color: rgba(75, 192, 192, 0.8);"></div>
            <span>Doanh thu thực tế</span>
        </div>
    </div>

    <div class="legend-controls">
        <button type="button" class="reset-legend-btn" id="resetLegend">
            <i class="bi bi-arrow-clockwise"></i> Hiển thị tất cả
        </button>
    </div>

    <div class="stats-summary" id="statsSummary">
        <!-- Sẽ được cập nhật bằng JavaScript -->
    </div>
</div>