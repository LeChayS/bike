@model bike.Models.HoaDon
@{
    ViewData["Title"] = $"Chi tiết hóa đơn HD{Model.MaHoaDon:D6}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles{
    <link rel="stylesheet" href="~/css/quanlyhoadon/qlhoadon-detail.css" />
}

<div class="invoice-container">
    <div class="invoice-card">
        <!-- Header -->
        <div class="invoice-header">
            <div class="invoice-number">
                <i class="bi bi-receipt"></i> HD@(Model.MaHoaDon.ToString("D6"))
            </div>
            <div class="invoice-status">
                @Model.TrangThai
            </div>
            <p class="mb-0 mt-3">Ngày tạo: @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        
        <!-- Body -->
        <div class="invoice-body">
            <!-- Thông tin hóa đơn -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-info-circle"></i> Thông tin hóa đơn
                </h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Mã hóa đơn</div>
                            <div class="info-value">HD@(Model.MaHoaDon.ToString("D6"))</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Mã hợp đồng liên quan</div>
                            <div class="info-value">
                                <a asp-controller="QuanLyHopDong" asp-action="ChiTiet" asp-route-id="@Model.MaHopDong" 
                                   class="text-decoration-none fw-bold text-primary">
                                    HD@(Model.MaHopDong.ToString("D6"))
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày thanh toán</div>
                            <div class="info-value">@Model.NgayThanhToan.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Người tạo</div>
                            <div class="info-value">@(Model.NguoiTao?.Ten ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>

            <!-- Thông tin khách hàng -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-person-fill"></i> Thông tin khách hàng
                </h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Họ và tên</div>
                            <div class="info-value">@Model.HopDong?.HoTenKhach</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số điện thoại</div>
                            <div class="info-value">@Model.HopDong?.SoDienThoai</div>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">CCCD/CMND</div>
                            <div class="info-value">@Model.HopDong?.SoCCCD</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Địa chỉ</div>
                            <div class="info-value">@(Model.HopDong?.DiaChi ?? "Không có")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>

            <!-- Thông tin xe -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-bicycle"></i> Thông tin xe thuê
                </h3>
                
                @if (Model.HopDong?.ChiTietHopDong?.Any() == true)
                {
                    @if (Model.HopDong.ChiTietHopDong.Count == 1)
                    {
                        var xeDau = Model.HopDong.ChiTietHopDong.First();
                        <div class="vehicle-card">
                            <div class="vehicle-header">
                                <div>
                                    <i class="bi bi-bicycle"></i> @xeDau.Xe?.TenXe - @xeDau.Xe?.BienSoXe
                                </div>
                            </div>
                            <div class="vehicle-body">
                                <div class="vehicle-info-grid">
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Hãng xe</div>
                                        <div class="vehicle-info-value">@xeDau.Xe?.HangXe</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Dòng xe</div>
                                        <div class="vehicle-info-value">@xeDau.Xe?.DongXe</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Giá thuê/ngày</div>
                                        <div class="vehicle-info-value text-danger">@xeDau.GiaThueNgay.ToString("N0")đ</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Thành tiền</div>
                                        <div class="vehicle-info-value text-success">@xeDau.ThanhTien.ToString("N0")đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <h6><i class="bi bi-list-ul"></i> Hợp đồng có @Model.HopDong.ChiTietHopDong.Count xe:</h6>
                            <div class="mt-3">
                                @foreach (var chiTiet in Model.HopDong.ChiTietHopDong)
                                {
                                    <div class="vehicle-card">
                                        <div class="vehicle-header">
                                            <div>
                                                <i class="bi bi-bicycle"></i> @chiTiet.Xe?.TenXe - @chiTiet.Xe?.BienSoXe
                                            </div>
                                        </div>
                                        <div class="vehicle-body">
                                            <div class="vehicle-info-grid">
                                                <div class="vehicle-info-item">
                                                    <div class="vehicle-info-label">Hãng xe</div>
                                                    <div class="vehicle-info-value">@chiTiet.Xe?.HangXe</div>
                                                </div>
                                                <div class="vehicle-info-item">
                                                    <div class="vehicle-info-label">Giá thuê/ngày</div>
                                                    <div class="vehicle-info-value text-danger">@chiTiet.GiaThueNgay.ToString("N0")đ</div>
                                                </div>
                                                <div class="vehicle-info-item">
                                                    <div class="vehicle-info-label">Số ngày thuê</div>
                                                    <div class="vehicle-info-value">@chiTiet.SoNgayThue ngày</div>
                                                </div>
                                                <div class="vehicle-info-item">
                                                    <div class="vehicle-info-label">Thành tiền</div>
                                                    <div class="vehicle-info-value text-success">@chiTiet.ThanhTien.ToString("N0")đ</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Không có thông tin xe
                    </div>
                }
            </div>

            <div class="section-divider"></div>

            <!-- Thông tin thời gian thuê -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-calendar-range"></i> Thông tin thời gian thuê
                </h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày nhận xe</div>
                            <div class="info-value">@Model.HopDong?.NgayNhanXe.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày trả xe thực tế</div>
                            <div class="info-value">@Model.HopDong?.NgayTraXeThucTe?.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số ngày thuê</div>
                            <div class="info-value">@Model.HopDong?.SoNgayThue ngày</div>
                        </div>
                    </div>
                    @if (Model.HopDong?.ChiTietHopDong?.Any() == true)
                    {
                        var xeDau = Model.HopDong.ChiTietHopDong.First();
                        <div class="col-md-6">
                            <div class="info-row">
                                <div class="info-label">Giá thuê/ngày</div>
                                <div class="info-value">@xeDau.GiaThueNgay.ToString("N0")đ</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Ghi chú -->
            @if (!string.IsNullOrEmpty(Model.GhiChu))
            {
                <div class="section-divider"></div>
                <div class="info-section">
                    <h3 class="section-title">
                        <i class="bi bi-chat-left-text"></i> Ghi chú
                    </h3>
                    <div class="info-row">
                        <div class="info-label">Nội dung</div>
                        <div class="info-value">@Model.GhiChu</div>
                    </div>
                </div>
            }

            <!-- Tổng kết thanh toán -->
            <div class="financial-summary">
                <h3><i class="bi bi-calculator"></i> TỔNG TIỀN THANH TOÁN</h3>
                <div class="total-amount">@Model.SoTien.ToString("N0")đ</div>
                <p class="mb-0">
                    <i class="bi bi-check-circle-fill"></i> Đã thanh toán đầy đủ
                </p>
            </div>

            <!-- Action buttons -->
            <div class="action-section no-print">
                <div class="dropdown">
                    <button class="btn btn-print dropdown-toggle" type="button" id="printDropdown" onclick="togglePrintDropdown(event)">
                        <i class="bi bi-printer"></i> In hóa đơn <i class="bi bi-chevron-down"></i>
                    </button>
                    <ul class="dropdown-menu" id="printDropdownMenu" style="display: none;">
                        <li>
                            <a class="dropdown-item" href="@Url.Action("InHoaDon", "QuanLyHoaDon", new { id = Model.MaHoaDon })" target="_blank">
                                <i class="bi bi-file-earmark-text"></i> In hóa đơn chi tiết
                            </a>
                        </li>
                        <li>
                            <button type="button" class="dropdown-item" onclick="printCurrentPage(event)">
                                <i class="bi bi-printer-fill"></i> In trang hiện tại
                            </button>
                        </li>
                        <li>
                            <button type="button" class="dropdown-item" onclick="printInvoiceOnly(event)">
                                <i class="bi bi-receipt"></i> In hóa đơn đơn giản
                            </button>
                        </li>
                    </ul>
                </div>
                <a asp-action="Index" class="btn btn-back">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            <!-- Footer thông tin công ty (chỉ hiện khi in) -->
            <div style="display: none;" class="print-only">
                <div class="section-divider"></div>
                <div class="text-center mt-4">
                    <h4>CÔNG TY CHO THUÊ XE MÁY SÀI GÒN</h4>
                    <p>Địa chỉ: 95/38 Nguyễn Văn Trỗi, Phường 12, Quận Phú Nhuận, TP.HCM</p>
                    <p>Điện thoại: 0908.630.065 | Email: info@chothuexe.com</p>
                    <p><strong>Cảm ơn quý khách đã sử dụng dịch vụ!</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Function toggle dropdown
        function togglePrintDropdown(event) {
            event.preventDefault();
            event.stopPropagation();
            
            var dropdownMenu = document.getElementById('printDropdownMenu');
            if (dropdownMenu.style.display === 'none' || dropdownMenu.style.display === '') {
                dropdownMenu.style.display = 'block';
            } else {
                dropdownMenu.style.display = 'none';
            }
        }

        // Đóng dropdown khi click ra ngoài
        document.addEventListener('click', function(event) {
            var dropdown = document.querySelector('.dropdown');
            var dropdownMenu = document.getElementById('printDropdownMenu');
            
            if (!dropdown.contains(event.target)) {
                dropdownMenu.style.display = 'none';
            }
        });

        // Function in trang hiện tại
        function printCurrentPage(event) {
            event.preventDefault();
            event.stopPropagation();
            
            // Đóng dropdown trước khi in
            document.getElementById('printDropdownMenu').style.display = 'none';
            window.print();
        }

        // Function in hóa đơn đơn giản
        function printInvoiceOnly(event) {
            event.preventDefault();
            event.stopPropagation();
            
            // Đóng dropdown trước khi in
            document.getElementById('printDropdownMenu').style.display = 'none';
            
            // Tạo một cửa sổ mới với nội dung hóa đơn đơn giản
            var printWindow = window.open('', '_blank', 'width=800,height=600');
            var invoiceContent = `
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Hóa đơn HD${@Model.MaHoaDon.ToString("D6")}</title>
                    <style>
                        body { font-family: Arial, sans-serif; margin: 20px; }
                        .invoice-header { text-align: center; margin-bottom: 30px; }
                        .invoice-title { font-size: 24px; font-weight: bold; margin-bottom: 10px; }
                        .invoice-info { margin-bottom: 20px; }
                        .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; }
                        .total-amount { font-size: 20px; font-weight: bold; text-align: center; margin: 20px 0; }
                        .footer { text-align: center; margin-top: 30px; font-size: 12px; }
                        @@media print { body { margin: 0; } }
                    </style>
                </head>
                <body>
                    <div class="invoice-header">
                        <div class="invoice-title">HÓA ĐƠN THANH TOÁN</div>
                        <div>HD${@Model.MaHoaDon.ToString("D6")}</div>
                        <div>Ngày: ${new Date().toLocaleDateString('vi-VN')}</div>
                    </div>
                    
                    <div class="invoice-info">
                        <div class="info-row">
                            <span><strong>Khách hàng:</strong></span>
                            <span>${'@Model.HopDong?.HoTenKhach'}</span>
                        </div>
                        <div class="info-row">
                            <span><strong>Số điện thoại:</strong></span>
                            <span>${'@Model.HopDong?.SoDienThoai'}</span>
                        </div>
                        <div class="info-row">
                            <span><strong>Hợp đồng:</strong></span>
                            <span>HD${'@Model.MaHopDong.ToString("D6")'}</span>
                        </div>
                    </div>
                    
                    <div class="total-amount">
                        TỔNG TIỀN: ${'@Model.SoTien.ToString("N0")'}đ
                    </div>
                    
                    <div class="footer">
                        <p>CÔNG TY CHO THUÊ XE MÁY SÀI GÒN</p>
                        <p>95/38 Nguyễn Văn Trỗi, Phường 12, Quận Phú Nhuận, TP.HCM</p>
                        <p>Điện thoại: 0908.630.065</p>
                    </div>
                </body>
                </html>
            `;
            
            printWindow.document.write(invoiceContent);
            printWindow.document.close();
            
            // Tự động in sau khi load xong
            printWindow.onload = function() {
                printWindow.print();
            };
        }
    </script>
}