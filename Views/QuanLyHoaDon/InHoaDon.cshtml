@model bike.Models.HoaDon
@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hóa đơn HD@(Model.MaHoaDon.ToString("D6"))</title>
    <link rel="stylesheet" href="~/css/quanlyhoadon/qlhoadon-print.css" />
</head>
<body>
    <!-- Nút in -->
    <button class="print-btn no-print" onclick="window.print()">
        🖨️ In Bill
    </button>

    <div class="invoice-container">
        <!-- Header -->
        <div class="bill-header">
            <div class="bill-company">CHO THUE XE MAY SAI GON</div>
            <div class="bill-contact">
                95/38 Nguyen Van Troi, P.12, Q.Phu Nhuan<br>
                Tel: 0908.630.065
            </div>
        </div>

        <!-- Title -->
        <div class="bill-title">HOA DON THANH TOAN</div>
        
        <!-- Bill Info -->
        <div class="bill-info">
            <div class="bill-line">
                <span>So HD:</span>
                <span>HD@(Model.MaHoaDon.ToString("D6"))</span>
            </div>
            <div class="bill-line">
                <span>Ngay:</span>
                <span>@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</span>
            </div>           
        </div>

        <div class="bill-separator"></div>

        <!-- Customer Info -->
        <div class="bill-info">
            <div class="bill-line">
                <span>Khach hang:</span>
                <span>@Model.HopDong?.HoTenKhach</span>
            </div>
            <div class="bill-line">
                <span>SDT:</span>
                <span>@Model.HopDong?.SoDienThoai</span>
            </div>           
        </div>

        <div class="bill-separator"></div>

        <!-- Service Info -->
        <div class="bill-info">
            <div style="font-weight: bold; margin-bottom: 5px;">DICH VU THUE XE:</div>
            <div class="bill-line">
                <span>Xe:</span>
                <span>
                    @if (Model.HopDong?.ChiTietHopDong?.Any() == true)
                    {
                        var xeDau = Model.HopDong.ChiTietHopDong.First();
                        @xeDau.Xe?.TenXe
                        @if (Model.HopDong.ChiTietHopDong.Count > 1)
                        {
                            <text> (+@(Model.HopDong.ChiTietHopDong.Count - 1) xe)</text>
                        }
                    }
                    else
                    {
                        <text>Không có xe</text>
                    }
                </span>
            </div>           
            <div class="bill-line">
                <span>Ngay nhan:</span>
                <span>@Model.HopDong?.NgayNhanXe.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="bill-line">
                <span>Ngay tra:</span>
                <span>@Model.HopDong?.NgayTraXeThucTe?.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="bill-line">
                <span>So ngay:</span>
                <span>@Model.HopDong?.SoNgayThue ngay</span>
            </div>
            <div class="bill-line">
                <span>Gia/ngay:</span>
                <span>
                    @if (Model.HopDong?.ChiTietHopDong?.Any() == true)
                    {
                        var xeDau = Model.HopDong.ChiTietHopDong.First();
                        @xeDau.GiaThueNgay.ToString("N0")
                        <text>đ</text>
                        @if (Model.HopDong.ChiTietHopDong.Count > 1)
                        {
                            <text> (TB)</text>
                        }
                    }
                    else
                    {
                        <text>0đ</text>
                    }
                </span>
            </div>
        </div>

        <div class="bill-separator"></div>

        <!-- Total -->
        <div class="bill-total">
            TONG TIEN: @Model.SoTien.ToString("N0")đ<br>
            (@Model.TrangThai)<br>
            Ngay TT: @Model.NgayThanhToan.ToString("dd/MM/yyyy")
        </div>

        <!-- Note if exists -->
        @if (!string.IsNullOrEmpty(Model.GhiChu))
        {
            <div class="bill-separator"></div>
            <div style="font-size: 10px;">
                Ghi chu: @Model.GhiChu
            </div>
        }

        <!-- Footer -->
        <div class="bill-footer">
            CAM ON QUY KHACH!<br>
            Moi thac mac lien he: 0908.630.065
        </div>
    </div>

    <script>
        // Auto print khi load trang
        window.onload = function() {
            setTimeout(function() {
                window.print();
            }, 500);
        }

        // Close window after print
        window.onafterprint = function() {
            window.close();
        }
    </script>
</body>
</html> 