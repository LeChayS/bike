@model bike.Models.DatCho
@{
	ViewData["Title"] = "Xác Nhận Đặt Chỗ";
	Layout = "~/Views/Shared/_HomePage.cshtml";
}

@section Styles{
    <link rel="stylesheet" href="~/css/quanlydatcho/qldatcho-confirm.css" />
}

<div class="confirmation-container">
    <div class="confirmation-card">
        <!-- Header thành công -->
        <div class="confirmation-header">
            <i class="bi bi-check-circle success-icon"></i>
            <h2>Đặt Giữ Chỗ Thành Công!</h2>
            <p class="mb-0">Cảm ơn bạn đã sử dụng dịch vụ của chúng tôi</p>
        </div>

        <!-- Body -->
        <div class="confirmation-body">
            <!-- Mã đặt chỗ -->
            <div class="booking-code">
                <p class="mb-2">Mã đặt chỗ của bạn:</p>
                <h3>DC@(Model.MaDatCho.ToString("D6"))</h3>
            </div>

            <!-- Chi tiết đặt chỗ -->
            <h4 class="mb-3">Chi tiết đặt chỗ</h4>

            <div class="detail-item">
                <span class="detail-label">Xe đặt:</span>
                <span class="detail-value">@Model.Xe?.TenXe</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Biển số:</span>
                <span class="detail-value">@Model.Xe?.BienSoXe</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Người đặt:</span>
                <span class="detail-value">@Model.HoTen</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Số điện thoại:</span>
                <span class="detail-value">@Model.SoDienThoai</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Email:</span>
                <span class="detail-value">@Model.Email</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Ngày nhận xe:</span>
                <span class="detail-value">@Model.NgayNhanXe.ToString("dd/MM/yyyy")</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Ngày trả xe:</span>
                <span class="detail-value">@Model.NgayTraXe.ToString("dd/MM/yyyy")</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Số ngày thuê:</span>
                <span class="detail-value">@Model.SoNgayThue ngày</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Tổng tiền dự kiến:</span>
                <span class="detail-value text-danger">@Model.TongTienDuKien.ToString("N0")đ</span>
            </div>

            <!-- Lưu ý -->
            <div class="notice-box">
                <h5><i class="bi bi-info-circle"></i> Lưu ý quan trọng:</h5>
                <ul class="mb-0">
                    <li>Vui lòng mang theo mã đặt chỗ <strong>DC@(Model.MaDatCho.ToString("D6"))</strong> khi đến nhận xe</li>
                    <li>Chuẩn bị CCCD/CMND và giấy tờ tùy thân có ảnh</li>
                    <li>Thời gian làm việc: 8h00 - 20h00 hàng ngày</li>
                    <li>Hotline hỗ trợ: 0908.428.642 / 0908.630.065</li>
                </ul>
            </div>

            <!-- Buttons -->
            <div class="action-buttons">
                <button onclick="window.print()" class="btn btn-print">
                    <i class="bi bi-printer"></i> In phiếu
                </button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-home text-center text-decoration-none">
                    <i class="bi bi-house"></i> Về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Có thể thêm logic gửi email xác nhận ở đây
        console.log('Đặt chỗ thành công!');
    </script>
}
