@model IEnumerable<bike.Models.ChiTieu>
@{
    ViewData["Title"] = "Quản lý chi tiêu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; 
}
<div class="container-fluid">
    @if (ViewData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Lỗi:</strong> @ViewData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <i class="bi bi-wallet2 me-3" style="font-size: 2.5rem;"></i>
                <div>
                    <h2 class="mb-0">Quản lý chi tiêu</h2>
                    <p class="mb-0 text-white-50">Theo dõi và quản lý các khoản chi của hệ thống</p>
                </div>
            </div>
            <a asp-action="Create" class="btn btn-light">
                <i class="bi bi-plus-circle me-2"></i>Thêm mới chi tiêu
            </a>
        </div>
    </div>
    <!-- Filter Section -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold" style="color: #764ba2;">
                <i class="bi bi-funnel me-2"></i>Lọc theo ngày
            </h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Từ ngày:</label>
                    <input type="date" class="form-control" id="startDate" name="startDate">
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">Đến ngày:</label>
                    <input type="date" class="form-control" id="endDate" name="endDate">
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div>
                        <button type="button" class="btn btn-primary" onclick="applyFilter()">
                            <i class="bi bi-search me-2"></i>Lọc
                        </button>
                        <button type="button" class="btn btn-secondary" id="clearFilterBtn" onclick="clearFilter()" style="display: none;">
                            <i class="bi bi-x-circle me-2"></i>Xóa lọc
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="d-flex align-items-end h-100">
                        <div class="text-muted">
                            <small id="filterStatus">Hiển thị tất cả dữ liệu</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>  
    <div class="row">
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Tổng chi hôm nay
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="tongChiHomNayValue" data-original-value="@ViewData["TongChiHomNay"]">@(((decimal)ViewData["TongChiHomNay"]).ToString("N0"))đ</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-calendar-day fs-2 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Tổng chi tháng này
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="tongChiThangNayValue" data-original-value="@ViewData["TongChiThangNay"]">@(((decimal)ViewData["TongChiThangNay"]).ToString("N0"))đ</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-calendar-month fs-2 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Tổng số khoản chi
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="tongSoKhoanChiValue" data-original-value="@Model.Count()">@Model.Count()</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-receipt-cutoff fs-2 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Search Section -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold" style="color: #764ba2;">
                <i class="bi bi-search me-2"></i>Tìm kiếm theo nội dung chi tiêu
            </h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <div class="input-group">
                        <input type="text" class="form-control" id="searchInput" placeholder="Nhập nội dung chi tiêu cần tìm..." />
                        <button class="btn btn-primary" type="button" onclick="performSearch()">
                            <i class="bi bi-search me-2"></i>Tìm kiếm
                        </button>
                        <button class="btn btn-secondary" type="button" id="clearSearchBtn" onclick="clearSearch()" style="display: none;">
                            <i class="bi bi-x-circle me-2"></i>Xóa tìm kiếm
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center h-100">
                        <div class="text-muted">
                            <small id="searchStatus">Nhập từ khóa để tìm kiếm</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold" style="color: #764ba2;">Danh sách các khoản chi</h6>
            <div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Nội dung chi tiêu</th>
                            <th>Số tiền</th>
                            <th>Ngày chi</th>
                            <th>Xe liên kết</th>
                            <th>Ghi chú</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="chiTieuTableBody">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.NoiDung)</td>
                                <td class="text-danger fw-bold">@item.SoTien.ToString("N0")đ</td>
                                <td>@item.NgayChi.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Xe != null)
                                    {
                                        <span class="badge bg-secondary">@item.Xe.BienSoXe</span>
                                    }
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.GhiChu)</td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-info btn-sm" title="Chi tiết" onclick="showChiTietModal(@item.Id)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button type="button" class="btn btn-danger btn-sm" title="Xóa" onclick="showDeleteModal(@item.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Custom Modal cho Chi tiết -->
<div id="chiTietModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h4>Chi tiết khoản chi</h4>
            <span class="custom-modal-close" onclick="closeChiTietModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <div id="chiTietContent">
                <div class="loading-spinner">
                    <div class="spinner"></div>
                    <p>Đang tải dữ liệu...</p>
                </div>
            </div>
        </div>
        <div class="custom-modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeChiTietModal()">Đóng</button>
        </div>
    </div>
</div>

<!-- Custom Modal cho Xóa -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content delete-modal-content">
        <div class="custom-modal-header delete-modal-header">
            <h4><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận xóa</h4>
            <span class="custom-modal-close" onclick="closeDeleteModal()">&times;</span>
        </div>
        <div class="custom-modal-body">
            <div id="deleteContent">
                <div class="loading-spinner">
                    <div class="spinner"></div>
                    <p>Đang tải dữ liệu...</p>
                </div>
            </div>
        </div>
        <div class="custom-modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">Hủy</button>
            <button type="button" class="btn btn-danger" id="confirmDeleteBtn" onclick="confirmDelete()">
                <i class="bi bi-trash me-2"></i>Xác nhận xóa
            </button>
        </div>
    </div>
</div>
@section Scripts {
    <style>
        .page-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 25px 30px;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
            .page-header h2 {
                font-weight: 600;
            }
        .card .card-header h6 {
            font-size: 1.1rem;
        }

        .table > tbody > tr > td {
            vertical-align: middle;
        }

        .btn-sm {
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        /* Border colors for stats cards */
        .border-left-danger {
            border-left: .25rem solid #e74a3b !important;
        }

        .border-left-warning {
            border-left: .25rem solid #f6c23e !important;
        }

        .border-left-info {
            border-left: .25rem solid #36b9cc !important;
        }

        .text-gray-300 {
            color: #dddfeb !important;
        }

        .text-gray-800 {
            color: #5a5c69 !important;
        }

        /* Custom Modal Styles */
        .custom-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
        }

        .custom-modal-content {
            background-color: #fefefe;
            margin: 5% auto;
            padding: 0;
            border-radius: 12px;
            width: 90%;
            max-width: 600px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            animation: modalSlideIn 0.3s ease-out;
        }

        @@keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .custom-modal-header {
            padding: 20px 25px;
            border-bottom: 1px solid #e3e6f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 12px 12px 0 0;
        }

        .custom-modal-header h4 {
            margin: 0;
            font-weight: 600;
        }

        .custom-modal-close {
            color: white;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            line-height: 1;
            transition: opacity 0.2s;
        }

        .custom-modal-close:hover {
            opacity: 0.7;
        }

        .custom-modal-body {
            padding: 25px;
            max-height: 400px;
            overflow-y: auto;
        }

        .custom-modal-footer {
            padding: 20px 25px;
            border-top: 1px solid #e3e6f0;
            text-align: right;
            background-color: #f8f9fc;
            border-radius: 0 0 12px 12px;
        }

        /* Chi tiết content styles */
        .chi-tiet-item {
            display: flex;
            margin-bottom: 15px;
            padding: 12px;
            background-color: #f8f9fc;
            border-radius: 8px;
            border-left: 4px solid #667eea;
        }

        .chi-tiet-label {
            font-weight: 600;
            color: #5a5c69;
            min-width: 120px;
            margin-right: 15px;
        }

        .chi-tiet-value {
            flex: 1;
            color: #2e2f37;
        }

        .chi-tiet-value.amount {
            color: #e74a3b;
            font-weight: 700;
            font-size: 1.1em;
        }

        /* Loading spinner */
        .loading-spinner {
            text-align: center;
            padding: 40px 20px;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Delete Modal Specific Styles */
        .delete-modal-content {
            max-width: 500px;
        }

        .delete-modal-header {
            background: linear-gradient(135deg, #e74a3b 0%, #dc3545 100%);
        }

        .delete-warning {
            background-color: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            color: #856404;
        }

        .delete-warning i {
            color: #f39c12;
            margin-right: 8px;
        }

        .delete-item {
            display: flex;
            margin-bottom: 12px;
            padding: 10px;
            background-color: #f8f9fc;
            border-radius: 6px;
            border-left: 3px solid #e74a3b;
        }

        .delete-label {
            font-weight: 600;
            color: #5a5c69;
            min-width: 100px;
            margin-right: 15px;
        }

        .delete-value {
            flex: 1;
            color: #2e2f37;
        }

        .delete-value.amount {
            color: #e74a3b;
            font-weight: 700;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .custom-modal-content {
                width: 95%;
                margin: 10% auto;
            }
            
            .chi-tiet-item {
                flex-direction: column;
            }
            
            .chi-tiet-label {
                min-width: auto;
                margin-right: 0;
                margin-bottom: 5px;
            }

            .delete-item {
                flex-direction: column;
            }
            
            .delete-label {
                min-width: auto;
                margin-right: 0;
                margin-bottom: 5px;
            }
        }
    </style>

    <script>
        // Hiển thị modal chi tiết
        function showChiTietModal(id) {
            const modal = document.getElementById('chiTietModal');
            const content = document.getElementById('chiTietContent');
            
            // Hiển thị modal
            modal.style.display = 'block';
            
            // Hiển thị loading
            content.innerHTML = `
                <div class="loading-spinner">
                    <div class="spinner"></div>
                    <p>Đang tải dữ liệu...</p>
                </div>
            `;
            
            // Gọi API để lấy dữ liệu
            fetch(`/QuanLyChiTieu/GetChiTiet/${id}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const chiTieu = data.data;
                        content.innerHTML = `
                            <div class="chi-tiet-item">
                                <div class="chi-tiet-label">Nội dung:</div>
                                <div class="chi-tiet-value">${chiTieu.noiDung}</div>
                            </div>
                            <div class="chi-tiet-item">
                                <div class="chi-tiet-label">Số tiền:</div>
                                <div class="chi-tiet-value amount">${chiTieu.soTien.toLocaleString('vi-VN')}đ</div>
                            </div>
                            <div class="chi-tiet-item">
                                <div class="chi-tiet-label">Ngày chi:</div>
                                <div class="chi-tiet-value">${chiTieu.ngayChi}</div>
                            </div>
                            <div class="chi-tiet-item">
                                <div class="chi-tiet-label">Xe liên kết:</div>
                                <div class="chi-tiet-value">${chiTieu.xeLienKet}</div>
                            </div>
                            <div class="chi-tiet-item">
                                <div class="chi-tiet-label">Ghi chú:</div>
                                <div class="chi-tiet-value">${chiTieu.ghiChu}</div>
                            </div>
                        `;
                    } else {
                        content.innerHTML = `
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                ${data.message}
                            </div>
                        `;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    content.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Có lỗi xảy ra khi tải dữ liệu. Vui lòng thử lại.
                        </div>
                    `;
                });
        }

        // Đóng modal chi tiết
        function closeChiTietModal() {
            const modal = document.getElementById('chiTietModal');
            modal.style.display = 'none';
        }

        // Đóng modal khi click bên ngoài
        window.onclick = function(event) {
            const chiTietModal = document.getElementById('chiTietModal');
            const deleteModal = document.getElementById('deleteModal');
            
            if (event.target === chiTietModal) {
                closeChiTietModal();
            }
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        }

        // Đóng modal khi nhấn ESC
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeChiTietModal();
                closeDeleteModal();
            }
        });

        // Biến global để lưu ID cần xóa
        let deleteItemId = null;

        // Hiển thị modal xóa
        function showDeleteModal(id) {
            deleteItemId = id;
            const modal = document.getElementById('deleteModal');
            const content = document.getElementById('deleteContent');
            
            // Hiển thị modal
            modal.style.display = 'block';
            
            // Hiển thị loading
            content.innerHTML = `
                <div class="loading-spinner">
                    <div class="spinner"></div>
                    <p>Đang tải dữ liệu...</p>
                </div>
            `;
            
            // Gọi API để lấy dữ liệu
            fetch(`/QuanLyChiTieu/GetDeleteData/${id}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const chiTieu = data.data;
                        content.innerHTML = `
                            <div class="delete-warning">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <strong>Bạn có chắc chắn muốn xóa khoản chi này không?</strong>
                                <br>Hành động này không thể hoàn tác.
                            </div>
                            <div class="delete-item">
                                <div class="delete-label">Nội dung:</div>
                                <div class="delete-value">${chiTieu.noiDung}</div>
                            </div>
                            <div class="delete-item">
                                <div class="delete-label">Số tiền:</div>
                                <div class="delete-value amount">${chiTieu.soTien.toLocaleString('vi-VN')}đ</div>
                            </div>
                            <div class="delete-item">
                                <div class="delete-label">Ngày chi:</div>
                                <div class="delete-value">${chiTieu.ngayChi}</div>
                            </div>
                            <div class="delete-item">
                                <div class="delete-label">Xe liên kết:</div>
                                <div class="delete-value">${chiTieu.xeLienKet}</div>
                            </div>
                        `;
                    } else {
                        content.innerHTML = `
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                ${data.message}
                            </div>
                        `;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    content.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Có lỗi xảy ra khi tải dữ liệu. Vui lòng thử lại.
                        </div>
                    `;
                });
        }

        // Đóng modal xóa
        function closeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            modal.style.display = 'none';
            deleteItemId = null;
        }

        // Xác nhận xóa
        function confirmDelete() {
            if (!deleteItemId) {
                alert('Không có dữ liệu để xóa');
                return;
            }

            const confirmBtn = document.getElementById('confirmDeleteBtn');
            const originalText = confirmBtn.innerHTML;
            
            // Disable button và hiển thị loading
            confirmBtn.disabled = true;
            confirmBtn.innerHTML = '<i class="spinner-border spinner-border-sm me-2"></i>Đang xóa...';

            // Tạo form để submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/QuanLyChiTieu/Delete/${deleteItemId}`;
            
            // Thêm antiforgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            form.appendChild(tokenInput);
            
            document.body.appendChild(form);
            form.submit();
        }

        // Filter functions
        let filterTimeout = null;

        // Apply filter
        function applyFilter() {
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;

            // Validate dates
            if (startDate && endDate && startDate > endDate) {
                alert('Ngày bắt đầu không thể lớn hơn ngày kết thúc');
                return;
            }

            // Show loading
            showFilterLoading();

            // Make AJAX request
            fetch('/QuanLyChiTieu/FilterByDate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    startDate: startDate,
                    endDate: endDate
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    updateTableAndStats(data.data);
                    updateFilterStatus(startDate, endDate);
                    // Show clear filter button if filter is applied
                    if (startDate || endDate) {
                        document.getElementById('clearFilterBtn').style.display = 'inline-block';
                    }
                } else {
                    alert('Có lỗi xảy ra: ' + data.message);
                    hideFilterLoading();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi lọc dữ liệu');
                hideFilterLoading();
            });
        }

        // Clear filter
        function clearFilter() {
            document.getElementById('startDate').value = '';
            document.getElementById('endDate').value = '';
            document.getElementById('filterStatus').textContent = 'Hiển thị tất cả dữ liệu';
            
            // Hide clear filter button
            document.getElementById('clearFilterBtn').style.display = 'none';
            
            // Reload page to show all data
            location.reload();
        }

        // Show loading state
        function showFilterLoading() {
            const tbody = document.getElementById('chiTieuTableBody');
            tbody.innerHTML = `
                <tr>
                    <td colspan="6" class="text-center py-4">
                        <div class="loading-spinner">
                            <div class="spinner"></div>
                            <p>Đang lọc dữ liệu...</p>
                        </div>
                    </td>
                </tr>
            `;
        }

        // Hide loading state
        function hideFilterLoading() {
            // This will be handled by the updateTableAndStats function
        }

        // Update table and statistics
        function updateTableAndStats(data) {
            // Update table
            const tbody = document.getElementById('chiTieuTableBody');
            if (data.rows && data.rows.length > 0) {
                tbody.innerHTML = data.rows.join('');
            } else {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-2">Không có dữ liệu trong khoảng thời gian đã chọn</p>
                        </td>
                    </tr>
                `;
            }

            // Update statistics
            document.getElementById('tongChiHomNayValue').textContent = data.tongChi.toLocaleString('vi-VN') + 'đ';
            document.getElementById('tongChiThangNayValue').textContent = data.tongChi.toLocaleString('vi-VN') + 'đ';
            document.getElementById('tongSoKhoanChiValue').textContent = data.soLuong;
        }

        // Update only table content (for search)
        function updateTableOnly(data) {
            const tbody = document.getElementById('chiTieuTableBody');
            
            if (data.rows && data.rows.length > 0) {
                tbody.innerHTML = data.rows.join('');
            } else {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center py-4">
                            <div class="text-muted">
                                <i class="bi bi-search fs-1"></i>
                                <p class="mt-2">Không tìm thấy kết quả nào</p>
                            </div>
                        </td>
                    </tr>
                `;
            }
        }
        // Update filter status
        function updateFilterStatus(startDate, endDate) {
            const statusElement = document.getElementById('filterStatus');
            
            if (startDate && endDate) {
                const start = new Date(startDate).toLocaleDateString('vi-VN');
                const end = new Date(endDate).toLocaleDateString('vi-VN');
                statusElement.textContent = `Đã lọc từ ${start} đến ${end}`;
            } else if (startDate) {
                const start = new Date(startDate).toLocaleDateString('vi-VN');
                statusElement.textContent = `Đã lọc từ ${start} trở đi`;
            } else if (endDate) {
                const end = new Date(endDate).toLocaleDateString('vi-VN');
                statusElement.textContent = `Đã lọc đến ${end}`;
            } else {
                statusElement.textContent = 'Hiển thị tất cả dữ liệu';
            }
        }

        // Auto-filter on date change (with debounce)
        function setupAutoFilter() {
            const startDateInput = document.getElementById('startDate');
            const endDateInput = document.getElementById('endDate');

            startDateInput.addEventListener('change', function() {
                clearTimeout(filterTimeout);
                filterTimeout = setTimeout(() => {
                    if (this.value || endDateInput.value) {
                        applyFilter();
                    } else {
                        // Hide clear button if no dates are selected
                        document.getElementById('clearFilterBtn').style.display = 'none';
                    }
                }, 500);
            });

            endDateInput.addEventListener('change', function() {
                clearTimeout(filterTimeout);
                filterTimeout = setTimeout(() => {
                    if (this.value || startDateInput.value) {
                        applyFilter();
                    } else {
                        // Hide clear button if no dates are selected
                        document.getElementById('clearFilterBtn').style.display = 'none';
                    }
                }, 500);
            });
        }

        // Store original statistics
        let originalStats = {
            tongChiHomNay: 0,
            tongChiThangNay: 0,
            tongSoKhoanChi: 0
        };

        // Initialize auto-filter when page loads
        document.addEventListener('DOMContentLoaded', function() {
            // Store original statistics from data attributes
            originalStats.tongChiHomNay = parseFloat(document.getElementById('tongChiHomNayValue').getAttribute('data-original-value'));
            originalStats.tongChiThangNay = parseFloat(document.getElementById('tongChiThangNayValue').getAttribute('data-original-value'));
            originalStats.tongSoKhoanChi = parseInt(document.getElementById('tongSoKhoanChiValue').getAttribute('data-original-value'));
            
            setupAutoFilter();
            setupSearch();
        });

        // Search functions
        let searchTimeout = null;

        // Setup search functionality
        function setupSearch() {
            const searchInput = document.getElementById('searchInput');
            
            // Add event listener for real-time search
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    if (this.value.trim()) {
                        performSearch();
                    } else {
                        clearSearch();
                    }
                }, 500); // Debounce 500ms
            });

            // Add event listener for Enter key
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    performSearch();
                }
            });
        }

        // Perform search
        function performSearch() {
            const searchTerm = document.getElementById('searchInput').value.trim();
            
            if (!searchTerm) {
                clearSearch();
                return;
            }

            // Show loading
            showSearchLoading();

            // Make AJAX request
            fetch('/QuanLyChiTieu/SearchByContent', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    searchTerm: searchTerm
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    updateTableOnly(data.data);
                    updateSearchStatus(searchTerm, data.data.soLuong);
                    // Show clear search button
                    document.getElementById('clearSearchBtn').style.display = 'inline-block';
                } else {
                    alert('Có lỗi xảy ra: ' + data.message);
                    hideSearchLoading();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi tìm kiếm');
                hideSearchLoading();
            });
        }

        // Clear search
        function clearSearch() {
            document.getElementById('searchInput').value = '';
            document.getElementById('searchStatus').textContent = 'Nhập từ khóa để tìm kiếm';
            
            // Hide clear search button
            document.getElementById('clearSearchBtn').style.display = 'none';
            
            // Show loading
            showSearchLoading();
            
            // Fetch original data without affecting statistics
            fetch('/QuanLyChiTieu/GetOriginalData', {
                method: 'GET'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    updateTableOnly(data.data);
                    // Restore original statistics
                    document.getElementById('tongChiHomNayValue').textContent = originalStats.tongChiHomNay.toLocaleString('vi-VN') + 'đ';
                    document.getElementById('tongChiThangNayValue').textContent = originalStats.tongChiThangNay.toLocaleString('vi-VN') + 'đ';
                    document.getElementById('tongSoKhoanChiValue').textContent = originalStats.tongSoKhoanChi;
                } else {
                    alert('Có lỗi xảy ra: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi tải lại dữ liệu');
            });
        }

        // Show search loading state
        function showSearchLoading() {
            const tbody = document.getElementById('chiTieuTableBody');
            tbody.innerHTML = `
                <tr>
                    <td colspan="6" class="text-center py-4">
                        <div class="loading-spinner">
                            <div class="spinner"></div>
                            <p>Đang tìm kiếm...</p>
                        </div>
                    </td>
                </tr>
            `;
        }
        // Hide search loading state
        function hideSearchLoading() {
            // This will be handled by the updateTableAndStats function
        }

        // Update search status
        function updateSearchStatus(searchTerm, resultCount) {
            const statusElement = document.getElementById('searchStatus');
            statusElement.textContent = `Tìm thấy ${resultCount} kết quả cho "${searchTerm}"`;
        }
    </script>
}